rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isVerified() {
      return isSignedIn() && (request.auth.token.email_verified == true || request.auth.token.firebase.sign_in_provider == 'google.com');
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Profile Rules ---
    match /profiles/{userId} {
      function isValidProfile(data) {
        return data.keys().hasAll(['email', 'role', 'createdAt']) &&
               data.email is string && data.email.size() <= 256 &&
               data.role in ['user', 'admin'] &&
               data.createdAt == request.time &&
               (!('displayName' in data) || data.displayName == null || (data.displayName is string && data.displayName.size() <= 128)) &&
               (!('photoURL' in data) || data.photoURL == null || (data.photoURL is string && data.photoURL.size() <= 1024));
      }

      allow get: if isSignedIn();
      allow list: if false; // Profiles shouldn't be listable by everyone
      allow create: if isOwner(userId) && isValidProfile(incoming()) && incoming().role == 'user';
      allow update: if isOwner(userId) && 
                    incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'photoURL']);
    }

    // --- Initiative Rules ---
    match /initiatives/{initiativeId} {
      function isValidInitiative(data) {
        return data.keys().hasAll(['title', 'content', 'authorId']) &&
               data.title is string && data.title.size() <= 256 &&
               data.content is string && data.content.size() <= 50000 &&
               data.authorId == request.auth.uid &&
               (!('category' in data) || (data.category is string && data.category.size() <= 128)) &&
               (!('status' in data) || (data.status in ['draft', 'published', 'archived'])) &&
               (!('likesCount' in data) || (data.likesCount is int));
      }

      allow list: if isSignedIn() && resource.data.status == 'published'; // Only published items in list
      allow list: if isOwner(resource.data.authorId); // Authors see all their own
      allow get: if isSignedIn() && (resource.data.status == 'published' || resource.data.authorId == request.auth.uid);
      
      allow create: if isVerified() && isValidInitiative(incoming()) && incoming().createdAt == request.time;
      allow update: if isVerified() && exists(/databases/$(database)/documents/profiles/$(request.auth.uid)) && (
        // Action: Edit content
        (isOwner(existing().authorId) && isValidInitiative(incoming()) && 
         incoming().diff(existing()).affectedKeys().hasOnly(['title', 'content', 'category', 'status', 'updatedAt'])) ||
        // Action: Like
        (isSignedIn() && incoming().diff(existing()).affectedKeys().hasOnly(['likesCount']) && 
         incoming().likesCount == existing().likesCount + 1)
      );
      allow delete: if isOwner(existing().authorId);
    }

    // --- Comment Rules ---
    match /initiatives/{initiativeId}/comments/{commentId} {
      function isValidComment(data) {
        return data.keys().hasAll(['text', 'authorId', 'initiativeId']) &&
               data.text is string && data.text.size() <= 1024 &&
               data.authorId == request.auth.uid &&
               data.initiativeId == initiativeId;
      }

      allow list, get: if isSignedIn();
      allow create: if isVerified() && isValidComment(incoming()) && incoming().createdAt == request.time;
      allow delete: if isOwner(existing().authorId);
    }
  }
}
